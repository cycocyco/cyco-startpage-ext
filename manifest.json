{
  "manifest_version": 3,
  "name": "CYCO起始",
  "version": "0.1.0",
  "description": "Warm Organic 风格的深色浏览器起始页：时钟、天气、搜索、书签、热搜",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage", "bookmarks", "geolocation"],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://api.bing.com/*",
    "https://suggestqueries.google.com/*",
    "https://suggestion.baidu.com/*",
    "https://dabenshi.cn/*",
    "https://60s.viki.moe/*",
    "https://api.iowen.cn/*",
    "https://api.bigdatacloud.net/*",
    "https://api.guiguiya.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
